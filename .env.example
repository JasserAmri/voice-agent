# LLM Provider: "azure" or "openrouter"
LLM_PROVIDER=azure

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-nano-2
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# OpenRouter (fallback — set LLM_PROVIDER=openrouter to use)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=google/gemini-3.1-flash-lite-preview

# MCP Server
MCP_SERVER_URL=https://mcp-servers.quicktext.im/mcp
MCP_BEARER_TOKEN=your-token-here
PORT=3000

# Cartesia TTS (primary — https://play.cartesia.ai)
CARTESIA_API_KEY=sk_car_...

# ElevenLabs TTS (legacy backup)
ELEVENLABS_API_KEY=sk_...

# Twilio (phone calls + SMS)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# LiveKit (real-time voice — future)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=API...
LIVEKIT_API_SECRET=your-secret-here
