# Required
OPENROUTER_API_KEY=sk-or-v1-...
MCP_SERVER_URL=https://mcp-servers.quicktext.im/mcp
MCP_BEARER_TOKEN=qt_...

# Optional — defaults to free model if not set
OPENROUTER_MODEL=google/gemini-3.1-flash-lite-preview
PORT=3000

# ElevenLabs TTS (optional — falls back to browser speech synthesis)
ELEVENLABS_API_KEY=sk_...

# Twilio phone integration (optional)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...
